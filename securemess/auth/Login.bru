meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "uuid": "{{createdUserUuid}}",
    "password": "{{password}}"
  }
}

vars:pre-request {
  uuid: {{uuid}}
  password: {{password}}
}

script:post-response {
  if (res.getStatus() === 200) {
    const body = res.getBody();
    bru.setEnvVar("accessToken", body.accessToken);
  }
}
